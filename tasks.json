{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "pip install -r requirements.txt"
    },
    {
      "label": "Run FastAPI",
      "type": "shell",
      "command": "uvicorn main:app --reload"
    },
    {
      "label": "Run Alembic migrations",
      "type": "shell",
      "command": "alembic upgrade head"
    },
    {
      "label": "Create Alembic revision",
      "type": "shell",
      "command": "alembic revision --autogenerate -m \"update models\""
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "pytest"
    }
  ]
}