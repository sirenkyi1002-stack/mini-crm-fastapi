{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run FastAPI server",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "main:app",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\.vscode"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run FastAPI server (no reload)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "main:app"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\.vscode"
      },
      "problemMatcher": []
    }
  ]
}
